{
  "name": "@agent-kevin/mcp-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/server.ts",
  "scripts": {
    "postinstall": "PLAYWRIGHT_BROWSERS_PATH=0 bunx playwright install chromium",
    "typecheck": "tsc",
    "start": "bun src/server.ts",
    "format": "bunx prettier --write \"**/*.{ts,json}\" --ignore-path .gitignore --ignore-path ../../.gitignore",
    "clean": "rm -rf node_modules",
    "test": "bun test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "~1.29.0",
    "@mozilla/readability": "~0.6.0",
    "dompurify": "~3.2.0",
    "googleapis": "~144.0.0",
    "jsdom": "~26.0.0",
    "linkedom": "~0.18.0",
    "marked": "~15.0.12",
    "pg": "~8.13.1",
    "playwright": "~1.60.0",
    "turndown": "~7.2.0",
    "zod": "~4.4.3"
  },
  "devDependencies": {
    "@types/bun": "~1.3.14",
    "@types/jsdom": "~21.1.7",
    "@types/pg": "~8.11.10",
    "@types/turndown": "~5.0.5",
    "prettier": "~3.8.3",
    "typescript": "~5.9.3"
  }
}
