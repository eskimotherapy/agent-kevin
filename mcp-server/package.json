{
  "name": "@agent-kevin/mcp-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/server.ts",
  "scripts": {
    "postinstall": "PLAYWRIGHT_BROWSERS_PATH=0 bunx playwright install chromium",
    "typecheck": "tsc",
    "start": "bun src/server.ts",
    "format": "npx prettier --write \"**/*.{ts,json}\" --ignore-path .gitignore --ignore-path ../../.gitignore",
    "clean": "rm -rf node_modules",
    "test": "bun test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "~1.29.0",
    "googleapis": "~144.0.0",
    "marked": "~15.0.12",
    "playwright": "~1.60.0",
    "zod": "~4.4.3"
  },
  "devDependencies": {
    "@types/bun": "~1.3.14",
    "prettier": "~3.8.3",
    "typescript": "~5.9.3"
  }
}
