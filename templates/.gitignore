# secrets
.env
.env.*
!.env.example
keys.json
certificates/
*.pem
*.key

# local overrides
.claude/settings.local.json

# runtime state (tokens, logs) — but TRACK the compile cursor: it's the only
# record of what's been ingested, and as a gitignored file it can be silently
# rolled back (e.g. by iCloud), which corrupts memory on the next blind compile.
.kevin/*
!.kevin/knowledge.json

# playwright capture artifacts (screenshots, pdfs, recordings — binary, regenerable)
reports/captures/

# obsidian (per-device pane layout + cache churn on every save — vault config stays tracked)
.obsidian/workspace.json
.obsidian/cache/

# os
.DS_Store
**/.DS_Store
Thumbs.db
