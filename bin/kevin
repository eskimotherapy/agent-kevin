#!/usr/bin/env bun
/**
 * `kevin` CLI — task + knowledge ops from outside Claude Code.
 *
 * Subcommands:
 *   kevin ping
 *   kevin capture [text] [--file=PATH] [--url=URL] [--kind=inbox|feedback] [--title=...] [--label=...] [--stdin]
 *   kevin session-capture --mode=session-end|pre-compact [--hook-protocol=claude] [--transcript=PATH --cwd=PATH --session-id=X] [--exclude PATH] [--format=claude]
 *   kevin session-start [--hook-protocol=claude]
 *   kevin task query [--project=NAME] [--status=...] [--priority=P0-P3]
 *   kevin task get <id>
 *   kevin task create --project=NAME --title=... --description=... [--priority=P2]
 *   kevin task update <id> [--status=...] [--priority=...] [--title=...] [--due=YYYY-MM-DD]
 *   kevin task close <id>
 *   kevin task thread <id> --message=... [--type=quote|info|warning]
 *   kevin task scan
 *
 *   kevin compile status
 *   kevin compile next          (prints the next work item JSON — doesn't synthesise)
 *   kevin compile write <itemId>
 *
 *   kevin prune
 *   kevin links
 *   kevin dashboard
 *
 *   kevin knowledge lint [--fix]
 */
import { existsSync, readFileSync } from 'node:fs';
import { dirname, resolve } from 'node:path';

// Resolve plugin root from this script's location so the CLI works whether
// you invoke it via bin/kevin, /full/path/to/bin/kevin, or the plugin PATH.
const PLUGIN_ROOT = resolve(import.meta.dir, '..');
process.env.KEVIN_PLUGIN_ROOT ??= PLUGIN_ROOT;

// Hydrate process.env from the nearest .claude/settings*.json `env` block so
// the CLI honours per-project paths (KEVIN_HOME, KEVIN_KNOWLEDGE, ...) without
// requiring the user to duplicate them in their shell rc. Order matches Claude
// Code: settings.local.json (machine-specific) overrides settings.json
// (committed). Existing shell env always wins.
function loadProjectEnv(): void {
  let dir = process.cwd();
  while (true) {
    for (const file of ['settings.local.json', 'settings.json']) {
      const path = resolve(dir, '.claude', file);
      if (!existsSync(path)) continue;
      try {
        const parsed = JSON.parse(readFileSync(path, 'utf-8')) as { env?: Record<string, string> };
        for (const [key, value] of Object.entries(parsed.env ?? {})) {
          if (typeof value === 'string') process.env[key] ??= value;
        }
      } catch {
        // malformed settings file — skip silently; user can run `kevin ping` to see resolved paths
      }
    }
    if (existsSync(resolve(dir, '.claude'))) {
      // First .claude/ wins, mirroring Claude Code. Anchor KEVIN_HOME to the
      // directory that owns this .claude/ so subsequent reads land in the right
      // tree regardless of which subdirectory the user invoked from.
      process.env.KEVIN_HOME ??= dir;
      return;
    }
    const parent = dirname(dir);
    if (parent === dir) return;
    dir = parent;
  }
}
loadProjectEnv();

const [, , group, command, ...args] = process.argv;

function flag(name: string): string | undefined {
  const f = args.find((a) => a.startsWith(`--${name}=`));
  return f?.slice(name.length + 3);
}

function flagArr(name: string): string[] {
  const value = flag(name);
  return value
    ? value
        .split(',')
        .map((s) => s.trim())
        .filter(Boolean)
    : [];
}

interface HookInput {
  session_id?: string;
  transcript_path?: string;
  cwd?: string;
}

/**
 * Parse hook JSON arriving on stdin. Falls back to escaping unescaped
 * backslashes (a workaround for some Claude hook payload variants that
 * emit Windows-style paths without re-escaping).
 */
function parseHookInput(raw: string): HookInput {
  try {
    return JSON.parse(raw);
  } catch {
    const fixed = raw.replace(/(?<!\\)\\(?!["\\])/g, '\\\\');
    return JSON.parse(fixed);
  }
}

const HELP = `\
kevin — Agent-Kevin CLI

Usage:
  kevin <group> <command> [flags]

Groups:
  ping                              Print resolved paths + timezone (sanity check)
  capture                           Capture text / a file / stdin into raw/inbox/ (or feedback.md) for the next compile
  session-capture                   Ingest a session transcript into raw/sessions/<today>.md (called by Claude Code hooks)
  session-start                     Emit dynamic context (today / last session tail / git activity) for the host's SessionStart hook
  task                              Read + mutate task files under projects/*/tasks/
  compile                           Knowledge-compile state (synthesis runs in Claude Code, not here)
  knowledge                         Wiki maintenance (lint)
  prune                             Delete memory/YYYY-MM-DD*.md older than 14 days
  links                             Rewrite bare task IDs + shorthand into [[wikilinks]]
  dashboard                         Rebuild the Agent OS dashboard at <HOME>/index.html + projects/TASKS.md (open in any browser)

Task commands:
  task query [--status=X] [--priority=P0-P3] [--project=NAME]
  task get <id>
  task create --project=NAME --title=... --description=... [--priority=P2] [--type=task|bug|idea|epic] [--due=YYYY-MM-DD] [--labels=a,b] [--depends_on=id1,id2]
  task update <id> [--status=X] [--priority=X] [--title=X] [--due=YYYY-MM-DD] [--blocked_by=X] [--labels=a,b]
  task close <id>
  task thread <id> --message=... [--type=quote|info|warning]
  task scan                         Resolve dependencies, surface overdue/stale/auto-* changes

Capture commands:
  capture "the thought"             Write inline text to raw/inbox/<ts>-<slug>.md (next compile distils it)
  capture --file=PATH               Capture a file's contents into raw/inbox/
  capture --url=URL                 Fetch a URL, strip HTML noise (<script>/<style>/<head>), store with source: url:<url> in frontmatter
  capture --stdin                   Read content from stdin (e.g. \`pbpaste | kevin capture --stdin\`)
  capture ... --kind=feedback       Append to raw/user/feedback.md instead of inbox/ (corrections/preferences)
  capture ... --title=X --label=Y   Optional metadata (slug source + frontmatter label)

Hook commands (internal — wired into Claude Code hooks; safe to run manually for testing):
  session-capture --mode=session-end|pre-compact --hook-protocol=claude
                                    Read hook JSON from stdin and append the transcript to raw/sessions/.
  session-capture --mode=... --transcript=PATH --cwd=PATH --session-id=X
                                    Plain-CLI mode — same logic without the hook envelope. Useful for testing.
  session-capture ... --exclude PATH (repeatable)
                                    Skip when cwd falls under PATH (multi-agent boundary; user-level hook only).
  session-capture ... --format=claude (default)
                                    Transcript-format adapter. Future: codex, etc.
  session-start [--hook-protocol=claude]
                                    Emit dynamic SessionStart context. Without the flag, prints the structured result for testing.

Knowledge commands:
  knowledge lint [--fix]            Structural health check; --fix rewrites stale wikilinks + inserts backlinks

Compile commands:
  compile status                    Show queue (pending sessions, feedback, specs)
  compile next                      Print next work item (no synthesis — run /agent-kevin:knowledge-compile for that)
  compile write <itemId>            Mark item complete (advanced — synthesis writes use this internally)

Environment:
  KEVIN_HOME=<path>                 Override agent home (default: cwd)
  KEVIN_PROJECTS=<path>             Override projects/ location (default: <HOME>/projects)
  KEVIN_KNOWLEDGE=<path>            Override knowledge/ location (default: <HOME>/knowledge)
  KEVIN_TIMEZONE=<tz>               Override timezone (default: system tz)

Examples:
  kevin capture "remember to follow up with tracy on constitution lodgement"
  kevin capture --file=~/notes/board-meeting.md --title="Board meeting 2026-05-28"
  kevin capture --url=https://docs.anthropic.com/en/docs/claude-code/overview
  pbpaste | kevin capture --stdin --title="Clipped article"
  kevin capture --kind=feedback "don't propose git push for local-only repos"
  kevin task query --status=active
  kevin task create --project=blog-dev --title="Draft launch post" --description="..." --priority=P1
  kevin dashboard
  kevin knowledge lint --fix
  kevin compile status
`;

async function run(): Promise<void> {
  if (!group || group === 'help' || group === '--help' || group === '-h') {
    console.log(HELP);
    process.exit(group ? 0 : 1);
  }

  // One info line per CLI invocation so file logs reveal user-invoked vs
  // MCP-invoked traffic. Lazy-imported because @/shared/log resolves KEVIN_HOME
  // and we want loadProjectEnv() to have run first.
  const { log } = await import(resolve(PLUGIN_ROOT, 'mcp-server/src/shared/log'));
  log.with('cli').info(`${group}${command ? ` ${command}` : ''}${args.length ? ` ${args.join(' ')}` : ''}`);

  if (group === 'ping') {
    const { FOLDERS, TIMEZONE } = await import(resolve(PLUGIN_ROOT, 'mcp-server/src/config'));
    console.log(
      JSON.stringify(
        {
          ok: true,
          timezone: TIMEZONE,
          home: FOLDERS.HOME,
          knowledge: FOLDERS.KNOWLEDGE,
          projects: FOLDERS.PROJECTS
        },
        null,
        2
      )
    );
    return;
  }

  if (group === 'task') {
    const TASKS = 'mcp-server/src/tasks';
    switch (command) {
      case 'query': {
        const { queryTasks } = await import(resolve(PLUGIN_ROOT, `${TASKS}/scan`));
        const filters: Record<string, string> = {};
        for (const k of ['status', 'priority', 'project']) {
          const v = flag(k);
          if (v) filters[k] = v;
        }
        const result = queryTasks(filters);
        console.log(
          JSON.stringify(
            result.map((t: { frontmatter: unknown }) => t.frontmatter),
            null,
            2
          )
        );
        return;
      }
      case 'get': {
        const id = args[0];
        if (!id) throw new Error('Usage: kevin task get <id>');
        const { findTaskById } = await import(resolve(PLUGIN_ROOT, `${TASKS}/scan`));
        const task = findTaskById(id);
        if (!task) {
          console.error(`Task not found: ${id}`);
          process.exit(1);
        }
        console.log(JSON.stringify(task, null, 2));
        return;
      }
      case 'create': {
        const project = flag('project');
        const title = flag('title');
        const description = flag('description');
        if (!project || !title || !description) {
          throw new Error('Required: --project --title --description');
        }
        const { createTask } = await import(resolve(PLUGIN_ROOT, `${TASKS}/mutate`));
        const res = createTask({
          project,
          title,
          description,
          assignee: [],
          priority: (flag('priority') as 'P0' | 'P1' | 'P2' | 'P3') ?? 'P2',
          type: (flag('type') as 'task' | 'bug' | 'idea' | 'epic') ?? 'task',
          labels: flagArr('labels'),
          due: flag('due') ?? '',
          depends_on: flagArr('depends_on')
        });
        console.log(JSON.stringify(res, null, 2));
        return;
      }
      case 'update': {
        const id = args[0];
        if (!id) throw new Error('Usage: kevin task update <id> --field=value ...');
        const fields: Record<string, string | string[]> = {};
        for (const k of ['status', 'priority', 'title', 'due', 'blocked_by']) {
          const v = flag(k);
          if (v) fields[k] = v;
        }
        if (flagArr('labels').length) fields.labels = flagArr('labels');
        const { updateTask } = await import(resolve(PLUGIN_ROOT, `${TASKS}/mutate`));
        updateTask(id, fields);
        console.log(JSON.stringify({ ok: true }));
        return;
      }
      case 'close': {
        const id = args[0];
        if (!id) throw new Error('Usage: kevin task close <id>');
        const { closeTask } = await import(resolve(PLUGIN_ROOT, `${TASKS}/mutate`));
        closeTask(id);
        console.log(JSON.stringify({ ok: true }));
        return;
      }
      case 'thread': {
        const id = args[0];
        const message = flag('message');
        if (!id || !message) throw new Error('Usage: kevin task thread <id> --message=...');
        const { appendThread } = await import(resolve(PLUGIN_ROOT, `${TASKS}/mutate`));
        appendThread(id, 'me', message, (flag('type') as 'quote' | 'info' | 'warning') ?? 'info');
        console.log(JSON.stringify({ ok: true }));
        return;
      }
      case 'scan': {
        const { scanAllTasks } = await import(resolve(PLUGIN_ROOT, `${TASKS}/scan`));
        const { resolveTasks } = await import(resolve(PLUGIN_ROOT, `${TASKS}/resolve`));
        const all = scanAllTasks();
        const result = resolveTasks(all);
        console.log(JSON.stringify({ scanned: all.length, ...result }, null, 2));
        return;
      }
      default:
        throw new Error(`Unknown task subcommand: ${command}`);
    }
  }

  if (group === 'compile') {
    const compile = await import(resolve(PLUGIN_ROOT, 'mcp-server/src/knowledge/compile'));
    switch (command) {
      case 'status':
        console.log(JSON.stringify(await compile.getStatus(), null, 2));
        return;
      case 'next':
        console.log(JSON.stringify(await compile.pickNext(), null, 2));
        return;
      case 'write': {
        const itemId = args[0];
        if (!itemId) throw new Error('Usage: kevin compile write <itemId>');
        console.log(JSON.stringify(await compile.markComplete(itemId), null, 2));
        return;
      }
      default:
        throw new Error(`Unknown compile subcommand: ${command}`);
    }
  }

  if (group === 'knowledge') {
    switch (command) {
      case 'lint': {
        const { run } = await import(resolve(PLUGIN_ROOT, 'mcp-server/src/knowledge/lint'));
        const summary = await run({ fixMode: args.includes('--fix') });
        console.log(JSON.stringify(summary, null, 2));
        if (summary.status === 'error') process.exit(1);
        return;
      }
      default:
        throw new Error(`Unknown knowledge subcommand: ${command}`);
    }
  }

  if (group === 'session-start') {
    const allArgs = [command, ...args].filter((a): a is string => Boolean(a));
    const localFlag = (name: string): string | undefined => {
      const f = allArgs.find((a) => a.startsWith(`--${name}=`));
      return f?.slice(name.length + 3);
    };

    const hookProtocol = localFlag('hook-protocol');
    if (hookProtocol !== undefined && hookProtocol !== 'claude') {
      throw new Error(`Unknown --hook-protocol: ${hookProtocol} (supported: claude)`);
    }

    const { sessionStart } = await import(resolve(PLUGIN_ROOT, 'mcp-server/src/knowledge/session-start'));
    const result = await sessionStart();

    if (hookProtocol === 'claude') {
      process.stdout.write(
        JSON.stringify({
          systemMessage: result.systemMessage,
          hookSpecificOutput: { hookEventName: 'SessionStart', additionalContext: result.additionalContext }
        })
      );
      if (result.error) process.exit(1);
    } else {
      console.log(JSON.stringify(result, null, 2));
    }
    return;
  }

  if (group === 'session-capture') {
    const allArgs = [command, ...args].filter((a): a is string => Boolean(a));
    const localFlag = (name: string): string | undefined => {
      const f = allArgs.find((a) => a.startsWith(`--${name}=`));
      return f?.slice(name.length + 3);
    };
    const localFlagArr = (name: string): string[] => {
      const values: string[] = [];
      for (let i = 0; i < allArgs.length; i += 1) {
        const a = allArgs[i];
        if (a === `--${name}` && i + 1 < allArgs.length) {
          values.push(allArgs[i + 1]);
          i += 1;
        } else if (a.startsWith(`--${name}=`)) {
          values.push(a.slice(name.length + 3));
        }
      }
      return values;
    };

    const mode = localFlag('mode');
    if (mode !== 'session-end' && mode !== 'pre-compact') {
      throw new Error(
        'Usage: kevin session-capture --mode=session-end|pre-compact [--hook-protocol=claude] [--transcript=PATH --cwd=PATH --session-id=X] [--exclude PATH] [--format=claude]'
      );
    }

    const hookProtocol = localFlag('hook-protocol');
    let transcriptPath: string;
    let cwd: string;
    let sessionId: string;

    if (hookProtocol === 'claude') {
      const raw = await new Promise<string>((resolveFn) => {
        let data = '';
        process.stdin.setEncoding('utf-8');
        process.stdin.on('data', (chunk) => (data += chunk));
        process.stdin.on('end', () => resolveFn(data));
      });
      const parsed = parseHookInput(raw);
      transcriptPath = parsed.transcript_path ?? '';
      cwd = parsed.cwd ?? '';
      sessionId = parsed.session_id ?? 'unknown';
    } else if (hookProtocol) {
      throw new Error(`Unknown --hook-protocol: ${hookProtocol}`);
    } else {
      transcriptPath = localFlag('transcript') ?? '';
      cwd = localFlag('cwd') ?? process.cwd();
      sessionId = localFlag('session-id') ?? 'cli';
    }

    const formatFlag = localFlag('format');
    if (formatFlag !== undefined && formatFlag !== 'claude') {
      throw new Error(`Unknown --format: ${formatFlag} (supported: claude)`);
    }

    const { captureSession } = await import(resolve(PLUGIN_ROOT, 'mcp-server/src/knowledge/session-capture'));
    const result = await captureSession({
      transcriptPath,
      cwd,
      sessionId,
      mode,
      excludes: localFlagArr('exclude'),
      format: formatFlag
    });

    if (hookProtocol === 'claude') {
      // Original script emitted a systemMessage for pre-compact (when saved). SessionEnd stays silent. Preserve.
      if (result.saved && mode === 'pre-compact') {
        const systemMessage = `💾 Saved ${result.turns} turn${result.turns === 1 ? '' : 's'} to ${result.filename}`;
        process.stdout.write(
          JSON.stringify({ systemMessage, hookSpecificOutput: { hookEventName: 'PreCompact' } })
        );
      }
    } else {
      console.log(JSON.stringify(result, null, 2));
    }
    return;
  }

  if (group === 'capture') {
    // Combine command + args so flags can land anywhere after `capture`. The
    // first non-flag arg (if any) is treated as inline positional text, so
    // `kevin capture "the thought"` works without --text=.
    const allArgs = [command, ...args].filter((a): a is string => Boolean(a));
    const localFlag = (name: string): string | undefined => {
      const f = allArgs.find((a) => a.startsWith(`--${name}=`));
      return f?.slice(name.length + 3);
    };
    const positional = allArgs.find((a) => !a.startsWith('--'));
    const wantStdin = allArgs.includes('--stdin');
    let text = positional ?? localFlag('text');
    if (!text && !localFlag('file') && !localFlag('url') && (wantStdin || !process.stdin.isTTY)) {
      text = await new Promise<string>((resolveFn) => {
        let data = '';
        process.stdin.setEncoding('utf-8');
        process.stdin.on('data', (chunk) => (data += chunk));
        process.stdin.on('end', () => resolveFn(data));
      });
    }
    const { capture } = await import(resolve(PLUGIN_ROOT, 'mcp-server/src/knowledge/capture'));
    const result = await capture({
      text,
      file: localFlag('file'),
      url: localFlag('url'),
      kind: localFlag('kind') as 'inbox' | 'feedback' | undefined,
      title: localFlag('title'),
      label: localFlag('label')
    });
    console.log(JSON.stringify(result, null, 2));
    return;
  }

  if (group === 'prune') {
    const { pruneMemory } = await import(resolve(PLUGIN_ROOT, 'mcp-server/src/knowledge/prune'));
    await pruneMemory();
    console.log(JSON.stringify({ ok: true }));
    return;
  }

  if (group === 'links') {
    const { rewriteAllWikilinks } = await import(resolve(PLUGIN_ROOT, 'mcp-server/src/knowledge/links'));
    const modified = await rewriteAllWikilinks();
    console.log(JSON.stringify({ modified, count: modified.length }, null, 2));
    return;
  }

  if (group === 'dashboard') {
    // The Agent OS dashboard replaced the old terminal TUI: regenerate
    // <HOME>/index.html from a fresh snapshot and print where it landed.
    // TASKS.md rebuilds first — the two derived views always refresh together.
    const { writeDashboard } = await import(resolve(PLUGIN_ROOT, 'mcp-server/src/tasks/dashboard'));
    const { writeDashboardHtml } = await import(resolve(PLUGIN_ROOT, 'mcp-server/src/status/html'));
    let tasks = null;
    try {
      tasks = writeDashboard();
    } catch {
      // best-effort — the HTML snapshot is the contract here
    }
    console.log(JSON.stringify({ ...(await writeDashboardHtml()), tasks }, null, 2));
    return;
  }

  throw new Error(`Unknown group: ${group}`);
}

run().catch((err) => {
  console.error(err instanceof Error ? err.message : err);
  process.exit(1);
});
